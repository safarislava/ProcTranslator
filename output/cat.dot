  "B3" [label="B3\l---\lcall prologue\lalloc s2\lr7 = param[0]\ls2 = r7\lreturn ''0''\l "];
  "B4" [label="B4\l---\lcall prologue\lalloc s3\lr8 = param[0]\ls3 = r8\lalloc s4\lr9 = param[8]\ls4 = r9\lreturn\l "];
  "B5" [label="B5\l---\lcall prologue\lalloc s5\lr10 = param[0]\ls5 = r10\lalloc s6\lr11 = param[8]\ls6 = r11\lreturn\l "];
  "B6" [label="B6\l---\l0 = store global 'false'\ljump B8\l "];
  "B7" [label="B7\l---\ljump B8\l "];
  "B8" [label="B8\l---\lr3 = load s0\loutput '5' = r3\lint_return\l "];
  "B9" [label="B9\l---\lr5 = load global 0\lbranch r5 ? B10 : B11\l "];
  "B10" [label="B10\l---\ljump B9\l "];
  "B11" [label="B11\l---\lreturn\l "];
  "B0" -> "B6" [label="true"];
  "B0" -> "B7" [label="false"];
  "B1" -> "B9";
  "B6" -> "B8";
  "B7" -> "B8";
  "B9" -> "B10" [label="true"];
  "B9" -> "B11" [label="false"];
  "B10" -> "B9";
  "B1" [fillcolor=lightgreen];
}
