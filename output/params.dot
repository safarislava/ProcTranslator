digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", style=filled, fillcolor=white, margin="0.2,0.1"];
  edge [fontname="Courier"];

  "B0" [label="B0\l---\lcall prologue\lalloc s0\lr0 = param[0]\ls0 = r0\lalloc s1\lr1 = param[1]\ls1 = r1\lalloc s2\lr2 = param[2]\ls2 = r2\lr3 = local s0 Add local s1\lr4 = r3 Multiply local s2\lreturn r4\l "];
  "B1" [label="B1\l---\lcall prologue\lalloc s3\ls3 = '9'\lalloc s4\ls4 = '-1'\lalloc s5\lr5 = call B0(local s3, local s4, '4')\ls5 = r5\loutput '4' = local s5\lreturn\l "];
  "B2" [label="B2\l---\lcall prologue\lalloc s6\lr7 = param[0]\ls6 = r7\lreturn '0'\l "];
  "B3" [label="B3\l---\lcall prologue\lalloc s7\lr8 = param[0]\ls7 = r8\lreturn ''0''\l "];
  "B4" [label="B4\l---\lcall prologue\lalloc s8\lr9 = param[0]\ls8 = r9\lalloc s9\lr10 = param[1]\ls9 = r10\lreturn\l "];
  "B5" [label="B5\l---\lcall prologue\lalloc s10\lr11 = param[0]\ls10 = r11\lalloc s11\lr12 = param[1]\ls11 = r12\lreturn\l "];
