digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier"];
  edge [fontname="Courier"];

  B0 [label="B0|call prologue\lalloc s0\ls0 = \"0\"\lalloc s1\ls1 = \"0\"\ljump B1\l"];
  B1 [label="B1|r0 = load s1\lr1 = r0 Less \"10\"\lbranch r1 ? B2 : B3\l"];
  B2 [label="B2|r2 = load s0\lr3 = r2 Add \"2\"\ls0 = r3\lr4 = load s1\lr5 = r4 Add \"1\"\ls1 = r5\ljump B1\l"];
  B3 [label="B3|r6 = load s0\lreturn r6\l"];
  B0 -> B1;
  B1 -> B2 [label="true"];
  B1 -> B3 [label="false"];
  B2 -> B1;
  B0 [style=filled, fillcolor=lightgreen];
}
