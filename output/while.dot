digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier"];
  edge [fontname="Courier"];

  B0 [label="B0|call prologue\lalloc s0\lr0 = param[0]\ls0 = r0\lr1 = load s0\lr2 = r1 Add \"5\"\lreturn r2\l"];
  B1 [label="B1|call prologue\lalloc s1\ls1 = \"0\"\ljump B4\l"];
  B2 [label="B2|"];
  B3 [label="B3|"];
  B4 [label="B4|branch \"true\" ? B5 : B6\l"];
  B5 [label="B5|r3 = load s1\lr4 = r3 Equal \"9\"\lbranch r4 ? B7 : B8\l"];
  B6 [label="B6|r11 = load s1\lreturn r11\l"];
  B7 [label="B7|r5 = load s1\lr6 = r5 Add \"1\"\ls1 = r6\ljump B8\l"];
  B8 [label="B8|r7 = load s1\lr8 = r7 Equal \"10\"\lbranch r8 ? B9 : B10\l"];
  B9 [label="B9|jump B6\l"];
  B10 [label="B10|jump B11\l"];
  B11 [label="B11|jump B12\l"];
  B12 [label="B12|r9 = load s1\lr10 = call B0(r9)\ls1 = r10\ljump B4\l"];
  B1 -> B4;
  B4 -> B5 [label="true"];
  B4 -> B6 [label="false"];
  B5 -> B7 [label="true"];
  B5 -> B8 [label="false"];
  B7 -> B8;
  B8 -> B9 [label="true"];
  B8 -> B10 [label="false"];
  B9 -> B6;
  B10 -> B11;
  B11 -> B12;
  B12 -> B4;
  B1 [style=filled, fillcolor=lightgreen];
}
