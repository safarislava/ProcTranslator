  "B10" [label="B10\l---\lr7 = load s1\lr8 = r7 Equal '10'\lbranch r8 ? B12 : B13\l "];
  "B11" [label="B11\l---\lr9 = load s1\lr10 = call B0(r9)\ls1 = r10\ljump B6\l "];
  "B12" [label="B12\l---\ljump B8\l "];
  "B13" [label="B13\l---\ljump B14\l "];
  "B14" [label="B14\l---\ljump B11\l "];
  "B1" -> "B6";
  "B6" -> "B7" [label="true"];
