digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier"];
  edge [fontname="Courier"];

  B0 [label="B0|call prologue\lalloc s0\llink r0 = param[0]\ls0 = r0\lr1 = load s0\lr2 = r1 Add \"5\"\lreturn r2\l"];
  B1 [label="B1|call prologue\lalloc s1\ls1 = \"0\"\ljump B2\l"];
  B2 [label="B2|branch \"true\" ? B3 : B4\l"];
  B3 [label="B3|r3 = load s1\lr4 = r3 Equal \"9\"\lbranch r4 ? B5 : B6\l"];
  B4 [label="B4|r11 = load s1\lreturn r11\l"];
  B5 [label="B5|r5 = load s1\lr6 = r5 Add \"1\"\ls1 = r6\ljump B6\l"];
  B6 [label="B6|r7 = load s1\lr8 = r7 Equal \"10\"\lbranch r8 ? B7 : B8\l"];
  B7 [label="B7|jump B4\l"];
  B8 [label="B8|jump B9\l"];
  B9 [label="B9|jump B10\l"];
  B10 [label="B10|r9 = load s1\lr10 = call B0(r9)\ls1 = r10\ljump B2\l"];
  B1 -> B2;
  B2 -> B3 [label="true"];
  B2 -> B4 [label="false"];
  B3 -> B5 [label="true"];
  B3 -> B6 [label="false"];
  B5 -> B6;
  B6 -> B7 [label="true"];
  B6 -> B8 [label="false"];
  B7 -> B4;
  B8 -> B9;
  B9 -> B10;
  B10 -> B2;
  B1 [style=filled, fillcolor=lightgreen];
}
