  void Main() {
      int seed = 42;
      int[100] a = new int[100];
      for (int i = 0; i < 100; i++) {
          seed = (seed * 1103515245 + 12345) % 2147483648;
          a[i] = seed;
      }

      int[100] b = new int[100];
