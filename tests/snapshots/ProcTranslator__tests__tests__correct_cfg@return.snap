---
source: src/tests.rs
expression: cfg.to_dot()
---
digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier"];
  edge [fontname="Courier"];

  B0 [label="{B0|r0 = param[0]\lr1 = const false\lbranch r1 ? B1 : B2\l}"];
  B1 [label="{B1|return\l}"];
  B2 [label="{B2|r2 = const false\lbranch r2 ? B3 : B4\l}"];
  B3 [label="{B3|return\l}"];
  B4 [label="{B4|return\l}"];
  B0 -> B1 [label="true"];
  B0 -> B2 [label="false"];
  B2 -> B3 [label="true"];
  B2 -> B4 [label="false"];
  B0 [style=filled, fillcolor=lightgreen];
}
