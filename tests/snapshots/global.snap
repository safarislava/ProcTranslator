expression: yaml
---
program: |
  String res = new String();

  class String {
      char[100] buffer = new char[100];
      int pointer = 1;

      void init() {
          this.buffer[0] = '\n';
          return;
      }

      void add(char v) {
          this.buffer[this.pointer++] = v;
          return;
      }

      bool end() {
          return this.buffer[this.pointer - 1] == '\0';
      }

      char get(int i) {
          return this.buffer[i];
      }
  }

  void Main() {
      res.init();

      char a = 'a';
      res.add(a);
      res.add(a);
      res.add(a);
      res.add('\0');

      if (res.end()) {
          print();
      }

      return;
  }

  void print() {
      for (int i = 1; true; i++) {
          char c = res.get(i);
          cout(5, c);
          if (c == '\0') {
              break;
          }
      }
      return;
  }
