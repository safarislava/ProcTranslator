program: |-
  void Main() {
      char[14] str = ['H', 'e', 'l', 'l', 'o', ',', ' ', 'W', 'o', 'r', 'l', 'd', '!', '\0'];
      for (int i = 0; i < 14; i++) {
          cout(5, str[i]);
      }
      return;
  }
