  "B4" [label="B4\l---\lcall prologue\lalloc s3\lr5 = param[0]\ls3 = r5\lalloc s4\lr6 = param[1]\ls4 = r6\lreturn\l "];
  "B5" [label="B5\l---\lcall prologue\lalloc s5\lr7 = param[0]\ls5 = r7\lalloc s6\lr8 = param[1]\ls6 = r8\lreturn\l "];
  "B6" [label="B6\l---\l0 = store global 'false'\ljump B8\l "];
  "B7" [label="B7\l---\ljump B8\l "];
  "B8" [label="B8\l---\loutput '5' = local s0\lint_return\l "];
