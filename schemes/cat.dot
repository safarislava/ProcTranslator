digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", style=filled, fillcolor=white, margin="0.2,0.1"];
  edge [fontname="Courier"];

  "B0" [label="B0\l---\linterrupt prologue\lalloc s0\lr0 = input '2'\ls0 = r0\lr1 = local s0 Equal ''\\0''\lbranch r1 ? B6 : B7\l "];
  "B1" [label="B1\l---\l0 = store global 'true'\lcall prologue\ljump B9\l "];
  "B2" [label="B2\l---\lcall prologue\lalloc s1\llocal s1 = param[0]\lreturn '0'\l "];
  "B3" [label="B3\l---\lcall prologue\lalloc s2\llocal s2 = param[0]\lreturn ''0''\l "];
  "B4" [label="B4\l---\lcall prologue\lalloc s3\llocal s3 = param[0]\lalloc s4\llocal s4 = param[1]\lreturn\l "];
  "B5" [label="B5\l---\lcall prologue\lalloc s5\llocal s5 = param[0]\lalloc s6\llocal s6 = param[1]\lreturn\l "];
  "B6" [label="B6\l---\l0 = store global 'false'\ljump B8\l "];
  "B7" [label="B7\l---\ljump B8\l "];
  "B8" [label="B8\l---\loutput '5' = local s0\lint_return\l "];
  "B9" [label="B9\l---\lbranch global 0 ? B10 : B11\l "];
  "B10" [label="B10\l---\ljump B9\l "];
  "B11" [label="B11\l---\lreturn\l "];
  "B0" -> "B6" [label="true"];
  "B0" -> "B7" [label="false"];
  "B1" -> "B9";
  "B6" -> "B8";
  "B7" -> "B8";
  "B9" -> "B10" [label="true"];
  "B9" -> "B11" [label="false"];
  "B10" -> "B9";
  "B1" [fillcolor=lightgreen];
}
