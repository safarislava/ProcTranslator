digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", style=filled, fillcolor=white, margin="0.2,0.1"];
  edge [fontname="Courier"];

  "B0" [label="B0\l---\lcall prologue\lbranch 'false' ? B5 : B6\l "];
  "B1" [label="B1\l---\lcall prologue\lalloc s0\llocal s0 = param[0]\lreturn '0'\l "];
  "B2" [label="B2\l---\lcall prologue\lalloc s1\llocal s1 = param[0]\lreturn ''0''\l "];
  "B3" [label="B3\l---\lcall prologue\lalloc s2\llocal s2 = param[0]\lalloc s3\llocal s3 = param[1]\lreturn\l "];
  "B4" [label="B4\l---\lcall prologue\lalloc s4\llocal s4 = param[0]\lalloc s5\llocal s5 = param[1]\lreturn\l "];
  "B5" [label="B5\l---\lreturn '1'\l "];
  "B6" [label="B6\l---\lbranch 'true' ? B7 : B8\l "];
  "B7" [label="B7\l---\lreturn '2'\l "];
  "B8" [label="B8\l---\lreturn '3'\l "];
  "B0" -> "B5" [label="true"];
  "B0" -> "B6" [label="false"];
  "B6" -> "B7" [label="true"];
  "B6" -> "B8" [label="false"];
  "B0" [fillcolor=lightgreen];
}
