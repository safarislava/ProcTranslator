digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", style=filled, fillcolor=white, margin="0.2,0.1"];
  edge [fontname="Courier"];

  "B0" [label="B0\l---\lcall prologue\lr0 = parameter 0 Add '5'\lreturn r0\l "];
  "B1" [label="B1\l---\lcall prologue\lalloc s0\ls0 = '0'\ljump B6\l "];
  "B2" [label="B2\l---\lcall prologue\lreturn '0'\l "];
  "B3" [label="B3\l---\lcall prologue\lreturn ''0''\l "];
  "B4" [label="B4\l---\lcall prologue\lreturn\l "];
  "B5" [label="B5\l---\lcall prologue\lreturn\l "];
  "B6" [label="B6\l---\lbranch 'true' ? B7 : B8\l "];
  "B7" [label="B7\l---\lr1 = local s0 Equal '9'\lbranch r1 ? B9 : B10\l "];
  "B8" [label="B8\l---\loutput '4' = local s0\lreturn local s0\l "];
  "B9" [label="B9\l---\lr2 = load s0\lr3 = r2 Add '1'\ls0 = r3\ljump B11\l "];
  "B10" [label="B10\l---\lr4 = local s0 Equal '10'\lbranch r4 ? B12 : B13\l "];
  "B11" [label="B11\l---\lr5 = call B0(local s0)\ls0 = r5\ljump B6\l "];
  "B12" [label="B12\l---\ljump B8\l "];
  "B13" [label="B13\l---\ljump B14\l "];
  "B14" [label="B14\l---\ljump B11\l "];
  "B1" -> "B6";
  "B6" -> "B7" [label="true"];
  "B6" -> "B8" [label="false"];
  "B7" -> "B9" [label="true"];
  "B7" -> "B10" [label="false"];
  "B9" -> "B11";
  "B10" -> "B12" [label="true"];
  "B10" -> "B13" [label="false"];
  "B11" -> "B6";
  "B12" -> "B8";
  "B13" -> "B14";
  "B14" -> "B11";
  "B1" [fillcolor=lightgreen];
}
