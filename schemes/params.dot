digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", style=filled, fillcolor=white, margin="0.2,0.1"];
  edge [fontname="Courier"];

  "B0" [label="B0\l---\lcall prologue\lalloc s0\llocal s0 = param[0]\lalloc s1\llocal s1 = param[1]\lalloc s2\llocal s2 = param[2]\lr0 = local s0 Add local s1\lr1 = r0 Multiply local s2\lreturn r1\l "];
  "B1" [label="B1\l---\lcall prologue\lalloc s3\ls3 = '9'\lalloc s4\ls4 = '-1'\lalloc s5\lr2 = call B0(local s3, local s4, '4')\ls5 = r2\loutput '4' = local s5\lreturn\l "];
  "B2" [label="B2\l---\lcall prologue\lalloc s6\llocal s6 = param[0]\lreturn '0'\l "];
  "B3" [label="B3\l---\lcall prologue\lalloc s7\llocal s7 = param[0]\lreturn ''0''\l "];
  "B4" [label="B4\l---\lcall prologue\lalloc s8\llocal s8 = param[0]\lalloc s9\llocal s9 = param[1]\lreturn\l "];
  "B5" [label="B5\l---\lcall prologue\lalloc s10\llocal s10 = param[0]\lalloc s11\llocal s11 = param[1]\lreturn\l "];
  "B1" [fillcolor=lightgreen];
}
