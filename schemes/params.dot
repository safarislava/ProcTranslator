digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", style=filled, fillcolor=white, margin="0.2,0.1"];
  edge [fontname="Courier"];

  "B0" [label="B0\l---\lcall prologue\lr0 = parameter 0 Add parameter 1\lr1 = r0 Multiply parameter 2\lreturn r1\l "];
  "B1" [label="B1\l---\lcall prologue\lalloc s0\ls0 = '9'\lalloc s1\ls1 = '-1'\lalloc s2\lr2 = call B0(local s0, local s1, '4')\ls2 = r2\loutput '4' = local s2\lreturn\l "];
  "B2" [label="B2\l---\lcall prologue\lreturn '0'\l "];
  "B3" [label="B3\l---\lcall prologue\lreturn ''0''\l "];
  "B4" [label="B4\l---\lcall prologue\lreturn\l "];
  "B5" [label="B5\l---\lcall prologue\lreturn\l "];
  "B1" [fillcolor=lightgreen];
}
