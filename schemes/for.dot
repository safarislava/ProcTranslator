digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", style=filled, fillcolor=white, margin="0.2,0.1"];
  edge [fontname="Courier"];

  "B0" [label="B0\l---\lcall prologue\lalloc s0\ls0 = '0'\lalloc s1\ls1 = '0'\ljump B5\l "];
  "B1" [label="B1\l---\lcall prologue\lreturn '0'\l "];
  "B2" [label="B2\l---\lcall prologue\lreturn ''0''\l "];
  "B3" [label="B3\l---\lcall prologue\lreturn\l "];
  "B4" [label="B4\l---\lcall prologue\lreturn\l "];
  "B5" [label="B5\l---\lr0 = local s1 Less '10'\lbranch r0 ? B6 : B7\l "];
  "B6" [label="B6\l---\lr1 = local s0 Add '2'\ls0 = r1\lr2 = load s1\lr3 = r2 Add '1'\ls1 = r3\ljump B5\l "];
  "B7" [label="B7\l---\loutput '4' = local s0\lreturn local s0\l "];
  "B0" -> "B5";
  "B5" -> "B6" [label="true"];
  "B5" -> "B7" [label="false"];
  "B6" -> "B5";
  "B0" [fillcolor=lightgreen];
}
