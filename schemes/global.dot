  "B4" [label="B4\l---\llink r0 = new object 2\llink r1 = new array[100]\llink r0[0] = link r1\llink r0[1] = '1'\l0 = store global link r0\lcall prologue\lr13 = call B0(global 0)\lalloc s0\ls0 = ''a''\lr14 = call B1(global 0, local s0)\lr15 = call B1(global 0, local s0)\lr16 = call B1(global 0, local s0)\lr17 = call B1(global 0, ''\\0'')\lr18 = call B2(global 0)\lbranch r18 ? B10 : B11\l "];
  "B5" [label="B5\l---\lcall prologue\lalloc s1\ls1 = '1'\ljump B13\l "];
  "B6" [label="B6\l---\lcall prologue\lreturn '0'\l "];
  "B7" [label="B7\l---\lcall prologue\lreturn ''0''\l "];
