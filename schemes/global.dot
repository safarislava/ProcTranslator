  "B9" [label="B9\l---\lcall prologue\lreturn\l "];
  "B10" [label="B10\l---\lr19 = call B5()\ljump B12\l "];
  "B11" [label="B11\l---\ljump B12\l "];
  "B12" [label="B12\l---\lreturn\l "];
  "B13" [label="B13\l---\lbranch 'true' ? B14 : B15\l "];
  "B14" [label="B14\l---\lalloc s2\lr20 = call B3(global 0, local s1)\ls2 = r20\loutput '5' = local s2\lr22 = local s2 Equal ''\\0''\lbranch r22 ? B16 : B17\l "];
  "B15" [label="B15\l---\lreturn\l "];
  "B16" [label="B16\l---\ljump B15\l "];
  "B17" [label="B17\l---\ljump B18\l "];
  "B18" [label="B18\l---\lr23 = load s1\lr24 = r23 Add '1'\ls1 = r24\ljump B13\l "];
  "B4" -> "B10" [label="true"];
  "B4" -> "B11" [label="false"];
  "B5" -> "B13";
  "B10" -> "B12";
  "B11" -> "B12";
  "B13" -> "B14" [label="true"];
  "B13" -> "B15" [label="false"];
