digraph CFG {
  rankdir=TB;
  node [shape=box, fontname="Courier", style=filled, fillcolor=white, margin="0.2,0.1"];
  edge [fontname="Courier"];

  "B0" [label="B0\l---\lcall prologue\llink r2 = load field parameter 0[0]\llink r2['0'] = ''\\n''\lreturn\l "];
  "B1" [label="B1\l---\lcall prologue\llink r3 = load field parameter 0[0]\lr4 = load field parameter 0[1]\lr5 = r4 Add '1'\lparameter 0[1] = r5\llink r3[r4] = parameter 1\lreturn\l "];
  "B2" [label="B2\l---\lcall prologue\llink r6 = load field parameter 0[0]\lr7 = load field parameter 0[1]\lr8 = r7 Sub '1'\lr9 = link r6[r8]\lr10 = r9 Equal ''\\0''\lreturn r10\l "];
